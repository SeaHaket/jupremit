# ─── Jupiter Developer Platform ───────────────────────────────────────────────
# Get your free key at https://portal.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Helius (recommended) or any Solana RPC provider
# Format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# DO NOT use NEXT_PUBLIC_ prefix — this key must stay server-side only
RPC_URL=https://api.mainnet-beta.solana.com

# ─── Network (optional) ───────────────────────────────────────────────────────
# Defaults to mainnet-beta if not set
# NETWORK=mainnet-beta
