# ─── Jupiter Developer Platform ───────────────────────────────────────────────
# Get your free key at https://portal.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── Solana RPC (server-side ONLY — never prefix with NEXT_PUBLIC_) ──────────
# Helius (recommended): https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Used by lib/solana.ts getConnection() — never exposed to the browser bundle.
RPC_URL=https://api.mainnet-beta.solana.com

# ─── Solana RPC (browser/client — key-less public endpoint ONLY) ──────────────
# Optional. Falls back to Solana public RPC if not set.
# Do NOT put a secret API key here — it ships to the browser bundle.
# NEXT_PUBLIC_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ─── App URL (used for CORS — set to your deployed domain) ───────────────────
NEXT_PUBLIC_APP_URL=https://jupremit.vercel.app

# ─── Network ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK=mainnet-beta
# NETWORK=mainnet-beta

# ─── Solana Program ───────────────────────────────────────────────────────────
NEXT_PUBLIC_PROGRAM_ID=your_program_id_here

# ─── Fonbnk widget ────────────────────────────────────────────────────────────
# Register at dashboard.fonbnk.com → API Settings to get these.
# FONBNK_SIGNATURE_SECRET must NEVER use NEXT_PUBLIC_ — stays server-side only.
FONBNK_SOURCE=your_fonbnk_source_id
FONBNK_SIGNATURE_SECRET=your_fonbnk_url_signature_secret
FONBNK_SANDBOX=true   # set to false in production

# ─── Protocol Fee Wallet ──────────────────────────────────────────────────────
# Receives the 0.20% protocol fee on every send (bundled in the SPL transfer tx).
# NEXT_PUBLIC_FEE_WALLET ships to the browser — use a dedicated fee-collection wallet.
# Falls back to empty string if not set (fee instruction skipped).
NEXT_PUBLIC_FEE_WALLET=your_fee_wallet_pubkey_here
# FEE_WALLET is the server-side alias used by API routes.
FEE_WALLET=your_fee_wallet_pubkey_here

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Create a free Redis database at https://console.upstash.com
# Copy the REST API URL and token from the database dashboard.
# If not set, rate limiting is disabled (fine for local dev).
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
